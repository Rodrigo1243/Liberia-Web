---
import { projects, getProject } from '../../../data/projects';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProject(slug!);
if (!project) return Astro.redirect('/en');

const lang = 'en';
---

<Layout lang={lang} title={project.title}>

  <div class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-12 h-16 lg:h-20 bg-[#0D0D0B]/90 backdrop-blur-md border-b border-white/5">
    <div class="flex items-center gap-3">
      <a href="/en/proyectos" class="flex items-center gap-2 text-white/50 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Projects
      </a>
      <span class="text-white/15">|</span>
      <a href="/en" class="text-white/30 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">
        Home
      </a>
    </div>
    <a href="/en">
      <img src="/images/isotipo.png" alt="Líbera Estudio" class="h-8 w-auto" style="filter: brightness(0) invert(1);" />
    </a>
    <div class="w-32"></div>
  </div>

  <main class="bg-[#0D0D0B] min-h-screen pt-20 lg:pt-24">
    <div
      x-data={`{
        active: 0,
        images: ${JSON.stringify(project.images)},
        setActive(i) { this.active = i; }
      }`}
      class="max-w-[1600px] mx-auto px-4 lg:px-10 py-10 lg:py-14"
    >
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <div class="flex-1 min-w-0">
          <div class="relative w-full bg-[#111]  overflow-hidden mb-4" style="aspect-ratio: 16/9;">
            <template x-for="(img, i) in images" :key="i">
              <img
                :src="img"
                :alt="`${project.title} — image ${i + 1}`"
                class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500"
                :class="active === i ? 'opacity-100' : 'opacity-0'"
                :loading="i === 0 ? 'eager' : 'lazy'"
              />
            </template>
            <button
              @click="setActive((active - 1 + images.length) % images.length)"
              class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10  bg-black/40 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white/70 hover:text-white hover:bg-black/60 transition-all duration-200 cursor-pointer"
              aria-label="Previous"
            >
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button
              @click="setActive((active + 1) % images.length)"
              class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10  bg-black/40 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white/70 hover:text-white hover:bg-black/60 transition-all duration-200 cursor-pointer"
              aria-label="Next"
            >
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="absolute bottom-4 right-4 text-white/50 text-xs tracking-widest">
              <span x-text="active + 1"></span> / <span x-text="images.length"></span>
            </div>
          </div>

          <div class="flex gap-3 overflow-x-auto pb-1">
            {project.images.map((img, i) => (
              <button
                x-on:click={`setActive(${i})`}
                class="flex-shrink-0 w-24 h-16 lg:w-32 lg:h-20  overflow-hidden border-2 transition-all duration-200 cursor-pointer"
                :class={`active === ${i} ? 'border-white/30 opacity-100' : 'border-transparent opacity-50 hover:opacity-80'`}
                aria-label={`View image ${i + 1}`}
              >
                <img src={img} alt="" class="w-full h-full object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        <div class="lg:w-80 xl:w-96 flex-shrink-0">
          <div class="bg-white/[0.04] border border-white/10  p-8 sticky top-28">
            <p class="text-white/60 text-[10px] tracking-[0.3em] uppercase font-medium mb-3">{project.category}</p>
            <h1 class="font-display text-white text-3xl font-light leading-tight mb-6">{project.title}</h1>
            <div class="w-8 h-px bg-white/20 mb-6"></div>
            <p class="text-white/60 text-sm leading-relaxed mb-8">{project.description.en}</p>
            <dl class="flex flex-col gap-5 mb-8">
              <div>
                <dt class="text-white/30 text-[10px] tracking-[0.25em] uppercase mb-1">Client</dt>
                <dd class="text-white/80 text-sm">{project.client}</dd>
              </div>
              <div>
                <dt class="text-white/30 text-[10px] tracking-[0.25em] uppercase mb-1">Country</dt>
                <dd class="text-white/80 text-sm">{project.location}</dd>
              </div>
              <div>
                <dt class="text-white/30 text-[10px] tracking-[0.25em] uppercase mb-1">Year</dt>
                <dd class="text-white/80 text-sm">{project.year}</dd>
              </div>
            </dl>
            <a
              href="/en#contacto"
              class="flex items-center justify-center gap-2 w-full border border-white/20 text-white/70 hover:text-white hover:bg-white/8 hover:border-white/30 text-xs tracking-[0.2em] uppercase px-6 py-3.5  transition-all duration-300 cursor-pointer"
            >
              Inquire about a similar project
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>
