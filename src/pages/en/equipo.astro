---
import Layout from '../../layouts/Layout.astro';

const members = [
  {
    name: 'Leonardo Perez',
    role: 'Director & Founder',
    bio: 'Architect specialized in digital visualization. He founded Líbera Estudio with a clear vision: every project deserves an image that does justice to its architecture. He leads the studio with a focus on quality, visual storytelling and a close relationship with every client.',
    image: '/images/Leonardo Perez.jpeg',
    location: 'Buenos Aires, Argentina',
    skills: ['Creative direction', 'Client relations', 'Visual strategy', '3ds Max', 'Corona Renderer'],
    instagram: '#',
    linkedin: '#',
    email: 'hola@liberaestudio.com',
  },
  {
    name: 'Valentina Cruz',
    role: 'Senior 3D Artist',
    bio: 'Specialized in modeling and lighting for high-complexity residential and commercial projects. Her eye for materials and artificial light makes every interior tell its own story.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Valentina&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['3ds Max', 'Corona Renderer', 'Lighting', 'V-Ray'],
    linkedin: '#',
    email: 'valentina@liberaestudio.com',
  },
  {
    name: 'Mateo Peralta',
    role: 'Animation & Motion',
    bio: 'Responsible for 3D walkthroughs, product animations and final video compositing. He combines technical skill with a cinematic sensibility to create pieces that move like architecture films.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Mateo&backgroundColor=111110',
    location: 'Córdoba, Argentina',
    skills: ['Lumion', 'D5 Render', 'After Effects', 'DaVinci Resolve'],
    linkedin: '#',
    email: 'mateo@liberaestudio.com',
  },
  {
    name: 'Lucía Montero',
    role: 'Post-production & Retouching',
    bio: 'The last step before an image leaves the studio passes through her hands. She masters photorealism, compositing and fine retouching with a precision that makes a render indistinguishable from a photograph.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Lucia&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['Photoshop', 'Lightroom', 'Compositing', 'Retouching'],
    linkedin: '#',
    email: 'lucia@liberaestudio.com',
  },
];
---

<Layout lang="en" title="Team — Líbera Estudio">

  <!-- Nav -->
  <div class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-12 h-16 lg:h-20 bg-[#0D0D0B]/90 backdrop-blur-md border-b border-white/5">
    <a href="/en#equipo" class="flex items-center gap-2 text-white/50 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back
    </a>
    <a href="/en">
      <img src="/images/isotipo.png" alt="Líbera Estudio" class="h-8 w-auto" style="filter: brightness(0) invert(1);" />
    </a>
    <a href="/es/equipo" class="text-white/30 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">ES</a>
  </div>

  <main class="bg-[#0D0D0B] min-h-screen">

    <!-- Hero intro -->
    <div class="pt-40 pb-24 px-6 lg:px-12 max-w-7xl mx-auto">
      <p class="text-white/60 text-xs tracking-[0.3em] uppercase font-medium mb-6">Team</p>
      <h1 class="font-display text-white text-5xl lg:text-7xl font-light leading-none mb-8 max-w-3xl">
        The people behind the work.
      </h1>
      <p class="text-white/40 text-base max-w-xl leading-relaxed">
        A small, passionate team committed to making every project look the way it deserves.
      </p>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/5"></div>

    <!-- Members -->
    {members.map((member, i) => (
      <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} min-h-[70vh]`}>

        <!-- Photo -->
        <div class="lg:w-1/2 relative overflow-hidden" style="min-height: 400px;">
          <img
            src={member.image}
            alt={member.name}
            class="absolute inset-0 w-full h-full object-cover grayscale"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0B]/60 via-transparent to-transparent"></div>
        </div>

        <!-- Info -->
        <div class={`lg:w-1/2 flex items-center px-8 lg:px-16 xl:px-24 py-16 lg:py-24 ${i % 2 === 0 ? 'lg:border-l' : 'lg:border-r'} border-white/5`}>
          <div class="max-w-md w-full">

            <span class="inline-block text-[10px] tracking-[0.28em] uppercase text-white/60 border border-white/15 bg-white/5 px-3 py-1 mb-6">
              {member.role}
            </span>

            <h2 class="font-display text-white text-4xl lg:text-5xl font-light mb-6 leading-tight">
              {member.name}
            </h2>

            <p class="text-white/50 text-base leading-relaxed mb-8">
              {member.bio}
            </p>

            <p class="text-white/25 text-xs tracking-widest uppercase mb-2">{member.location}</p>

            <div class="w-8 h-px bg-white/10/50 mb-8"></div>

            <!-- Skills -->
            <div class="flex flex-wrap gap-2 mb-10">
              {member.skills.map((skill) => (
                <span class="text-xs text-white/40 border border-white/10 px-3 py-1">{skill}</span>
              ))}
            </div>

            <!-- Social -->
            <div class="flex gap-2">
              {member.instagram && (
                <a href={member.instagram} target="_blank" rel="noopener" aria-label="Instagram"
                  class="w-9 h-9 border border-white/10 bg-white/5 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-colors duration-200">
                  <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              )}
              {member.linkedin && (
                <a href={member.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"
                  class="w-9 h-9 border border-white/10 bg-white/5 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-colors duration-200">
                  <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              )}
              {member.email && (
                <a href={`mailto:${member.email}`} aria-label="Email"
                  class="w-9 h-9 border border-white/10 bg-white/5 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-colors duration-200">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              )}
            </div>

          </div>
        </div>

      </div>

      <!-- Divider between members -->
      {i < members.length - 1 && (
        <div class="w-full h-px bg-white/5"></div>
      )}
    ))}

    <!-- Footer CTA -->
    <div class="py-24 px-6 lg:px-12 max-w-7xl mx-auto border-t border-white/5 mt-0 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <div>
        <p class="text-white/30 text-sm mb-2">Got a project in mind?</p>
        <p class="text-white/60 text-base">Let's work together.</p>
      </div>
      <a
        href="/en#contacto"
        class="flex items-center gap-3 border border-white/20 text-white/70 hover:text-white hover:bg-white/8 hover:border-white/30 text-xs tracking-[0.2em] uppercase px-8 py-4 transition-all duration-300"
      >
        Contact
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </main>

</Layout>
