---
import Layout from '../../layouts/Layout.astro';

const members = [
  {
    name: 'Leonardo Perez',
    role: 'Director & Founder',
    bio: 'Architect specialized in digital visualization. He founded Líbera Estudio with a clear vision: every project deserves an image that does justice to its architecture. He leads the studio with a focus on quality, visual storytelling and a close relationship with every client.',
    image: '/images/Leonardo Perez.jpeg',
    location: 'Buenos Aires, Argentina',
    skills: ['Creative direction', 'Client relations', 'Visual strategy', '3ds Max', 'Corona Renderer'],
    instagram: '#',
    linkedin: '#',
    email: 'hola@liberaestudio.com',
  },
  {
    name: 'Valentina Cruz',
    role: 'Senior 3D Artist',
    bio: 'Specialized in modeling and lighting for high-complexity residential and commercial projects. Her eye for materials and artificial light makes every interior tell its own story.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Valentina&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['3ds Max', 'Corona Renderer', 'Lighting', 'V-Ray'],
    linkedin: '#',
    email: 'valentina@liberaestudio.com',
  },
  {
    name: 'Mateo Peralta',
    role: 'Animation & Motion',
    bio: 'Responsible for 3D walkthroughs, product animations and final video compositing. He combines technical skill with a cinematic sensibility to create pieces that move like architecture films.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Mateo&backgroundColor=111110',
    location: 'Córdoba, Argentina',
    skills: ['Lumion', 'D5 Render', 'After Effects', 'DaVinci Resolve'],
    linkedin: '#',
    email: 'mateo@liberaestudio.com',
  },
  {
    name: 'Lucía Montero',
    role: 'Post-production & Retouching',
    bio: 'The last step before an image leaves the studio passes through her hands. She masters photorealism, compositing and fine retouching with a precision that makes a render indistinguishable from a photograph.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Lucia&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['Photoshop', 'Lightroom', 'Compositing', 'Retouching'],
    linkedin: '#',
    email: 'lucia@liberaestudio.com',
  },
];
---

<Layout lang="en" title="Team — Líbera Estudio">

  <!-- Nav -->
  <div class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-12 h-16 lg:h-20 bg-[#0D0D0B]/90 backdrop-blur-md border-b border-white/5">
    <a href="/en#equipo" class="flex items-center gap-2 text-white/50 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back
    </a>
    <a href="/en">
      <img src="/images/isotipo.png" alt="Líbera Estudio" class="h-8 w-auto" />
    </a>
    <a href="/es/equipo" class="text-white/30 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">ES</a>
  </div>

  <main class="bg-[#0D0D0B] min-h-screen">

    <!-- Hero intro -->
    <div class="pt-40 pb-24 px-6 lg:px-12 max-w-7xl mx-auto">
      <h1 class="font-display text-white text-5xl lg:text-7xl font-light leading-none max-w-3xl">
        Us.
      </h1>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/5"></div>

    <!-- Members -->
    {members.map((member, i) => (
      <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} min-h-[70vh]`}>

        <!-- Photo -->
        <div class="lg:w-1/2 relative overflow-hidden" style="min-height: 400px;">
          <img
            src={member.image}
            alt={member.name}
            class="absolute inset-0 w-full h-full object-cover grayscale"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0B]/60 via-transparent to-transparent"></div>
        </div>

        <!-- Info -->
        <div class={`lg:w-1/2 flex items-center px-8 lg:px-16 xl:px-24 py-16 lg:py-24 ${i % 2 === 0 ? 'lg:border-l' : 'lg:border-r'} border-white/5`}>
          <div class="max-w-md w-full">

            <p class="text-[10px] tracking-[0.28em] uppercase text-white/60 mb-6">
              {member.role}
            </p>

            <h2 class="font-display text-white text-4xl lg:text-5xl font-light mb-6 leading-tight">
              {member.name}
            </h2>

            <p class="text-white/25 text-xs tracking-widest uppercase mb-2">{member.location}</p>

            <div class="w-8 h-px bg-white/10/50 mb-8"></div>


          </div>
        </div>

      </div>

      <!-- Divider between members -->
      {i < members.length - 1 && (
        <div class="w-full h-px bg-white/5"></div>
      )}
    ))}

    <!-- Footer CTA -->
    <div class="py-24 px-6 lg:px-12 max-w-7xl mx-auto border-t border-white/5 mt-0 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <div>
        <p class="text-white/30 text-sm mb-2">Got a project in mind?</p>
        <p class="text-white/60 text-base">Let's work together.</p>
      </div>
      <a
        href="/en#contacto"
        class="flex items-center gap-3 text-white/60 hover:text-white text-xs tracking-[0.2em] uppercase py-4 transition-colors duration-300"
      >
        Contact
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </main>

</Layout>
