---
import Layout from '../../layouts/Layout.astro';

const members = [
  {
    name: 'Leonardo Perez',
    role: 'Director & Fundador',
    bio: 'Arquitecto especializado en visualización digital. Fundó Líbera Estudio con una visión clara: que cada proyecto merezca una imagen que haga justicia a su arquitectura. Dirige el estudio con foco en calidad, narrativa visual y relación cercana con cada cliente.',
    image: '/images/Leonardo Perez.jpeg',
    location: 'Buenos Aires, Argentina',
    skills: ['Dirección creativa', 'Relación con clientes', 'Estrategia visual', '3ds Max', 'Corona Renderer'],
    instagram: '#',
    linkedin: '#',
    email: 'hola@liberaestudio.com',
  },
  {
    name: 'Valentina Cruz',
    role: 'Artista 3D Senior',
    bio: 'Especializada en modelado e iluminación de proyectos residenciales y comerciales de alta complejidad. Su ojo para los materiales y la luz artificial hacen que cada interior cuente una historia propia.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Valentina&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['3ds Max', 'Corona Renderer', 'Iluminación', 'V-Ray'],
    linkedin: '#',
    email: 'valentina@liberaestudio.com',
  },
  {
    name: 'Mateo Peralta',
    role: 'Animación & Motion',
    bio: 'Responsable de los recorridos 3D, animaciones de producto y composición de video final. Combina técnica y sentido cinematográfico para crear piezas que se mueven como películas de arquitectura.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Mateo&backgroundColor=111110',
    location: 'Córdoba, Argentina',
    skills: ['Lumion', 'D5 Render', 'After Effects', 'DaVinci Resolve'],
    linkedin: '#',
    email: 'mateo@liberaestudio.com',
  },
  {
    name: 'Lucía Montero',
    role: 'Post-producción & Retoque',
    bio: 'El último paso antes de que una imagen salga del estudio pasa por sus manos. Domina el fotorrealismo, el compositing y el retoque fino con una precisión que distingue un render de una fotografía.',
    image: 'https://api.dicebear.com/7.x/avataaars/svg?seed=Lucia&backgroundColor=111110',
    location: 'Buenos Aires, Argentina',
    skills: ['Photoshop', 'Lightroom', 'Compositing', 'Retoque'],
    linkedin: '#',
    email: 'lucia@liberaestudio.com',
  },
];
---

<Layout lang="es" title="Equipo — Líbera Estudio">

  <!-- Nav -->
  <div class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 lg:px-12 h-16 lg:h-20 bg-[#0D0D0B]/90 backdrop-blur-md border-b border-white/5">
    <a href="/es#equipo" class="flex items-center gap-2 text-white/50 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M19 12H5M12 5l-7 7 7 7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </a>
    <a href="/es">
      <img src="/images/isotipo.png" alt="Líbera Estudio" class="h-8 w-auto" style="filter: brightness(0) invert(1);" />
    </a>
    <a href="/en/equipo" class="text-white/30 hover:text-white text-xs tracking-widest uppercase transition-colors duration-200">EN</a>
  </div>

  <main class="bg-[#0D0D0B] min-h-screen">

    <!-- Hero intro -->
    <div class="pt-40 pb-24 px-6 lg:px-12 max-w-7xl mx-auto">
      <p class="text-white/60 text-xs tracking-[0.3em] uppercase font-medium mb-6">Equipo</p>
      <h1 class="font-display text-white text-5xl lg:text-7xl font-light leading-none mb-8 max-w-3xl">
        Las personas detrás del trabajo.
      </h1>
      <p class="text-white/40 text-base max-w-xl leading-relaxed">
        Un equipo pequeño, apasionado y comprometido con hacer que cada proyecto se vea como merece.
      </p>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/5"></div>

    <!-- Members -->
    {members.map((member, i) => (
      <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} min-h-[70vh]`}>

        <!-- Photo -->
        <div class="lg:w-1/2 relative overflow-hidden" style="min-height: 400px;">
          <img
            src={member.image}
            alt={member.name}
            class="absolute inset-0 w-full h-full object-cover grayscale"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0B]/60 via-transparent to-transparent"></div>
        </div>

        <!-- Info -->
        <div class={`lg:w-1/2 flex items-center px-8 lg:px-16 xl:px-24 py-16 lg:py-24 ${i % 2 === 0 ? 'lg:border-l' : 'lg:border-r'} border-white/5`}>
          <div class="max-w-md w-full">

            <p class="text-[10px] tracking-[0.28em] uppercase text-white/60 mb-6">
              {member.role}
            </p>

            <h2 class="font-display text-white text-4xl lg:text-5xl font-light mb-6 leading-tight">
              {member.name}
            </h2>

            <p class="text-white/50 text-base leading-relaxed mb-8">
              {member.bio}
            </p>

            <p class="text-white/25 text-xs tracking-widest uppercase mb-2">{member.location}</p>

            <div class="w-8 h-px bg-white/10/50 mb-8"></div>


          </div>
        </div>

      </div>

      <!-- Divider between members -->
      {i < members.length - 1 && (
        <div class="w-full h-px bg-white/5"></div>
      )}
    ))}

    <!-- Footer CTA -->
    <div class="py-24 px-6 lg:px-12 max-w-7xl mx-auto border-t border-white/5 mt-0 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <div>
        <p class="text-white/30 text-sm mb-2">¿Tenés un proyecto en mente?</p>
        <p class="text-white/60 text-base">Trabajemos juntos.</p>
      </div>
      <a
        href="/es#contacto"
        class="flex items-center gap-3 border border-white/20 text-white/70 hover:text-white hover:bg-white/8 hover:border-white/30 text-xs tracking-[0.2em] uppercase px-8 py-4 transition-all duration-300"
      >
        Contacto
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

  </main>

</Layout>
