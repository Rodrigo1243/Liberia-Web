---
interface Member {
  name: string;
  role: string;
  bio: string;
  image: string;
  location: string;
  skills: string[];
  linkedin?: string;
  instagram?: string;
  email?: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    subtitle: string;
    cta: string;
    ctaLink: string;
    teamPageLabel: string;
    teamPageLink: string;
    members: Member[];
  };
  lang: string;
}

const { t, lang } = Astro.props;
const founder = t.members[0];

const quote = lang === 'es'
  ? 'La visualización arquitectónica es el alma de un proyecto antes de que exista.'
  : 'Architectural visualization is the soul of a project before it exists.';
---

<section id="equipo" class="bg-[#0D0D0B] overflow-hidden">

  <!-- Section label -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-28 lg:pt-40 pb-12" data-animate>
    <h2 class="font-display text-white text-4xl lg:text-5xl font-light">Nosotros.</h2>
  </div>

  <!-- Founder — full-width split layout -->
  <div class="flex flex-col lg:flex-row" style="min-height: 82vh;" data-animate>

    <!-- Left: large image -->
    <div class="relative lg:w-[62%] flex-shrink-0 overflow-hidden" style="min-height: 55vw; max-height: 90vh;">
      <img
        src={founder.image}
        alt={founder.name}
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="lazy"
      />
      <!-- subtle gradient so it bleeds into the dark bg on mobile -->
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-[#0D0D0B]/40 hidden lg:block"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0B]/70 via-transparent to-transparent lg:hidden"></div>
    </div>

    <!-- Right: info panel -->
    <div class="lg:w-[38%] flex-shrink-0 flex flex-col justify-between px-8 lg:px-12 xl:px-16 py-10 lg:py-14 border-t border-white/5 lg:border-t-0 lg:border-l lg:border-white/5">

      <!-- Top: role + name + quote -->
      <div>
        <p class="text-[10px] tracking-[0.28em] uppercase text-white/60 mb-6">
          {founder.role}
        </p>

        <h3 class="font-display text-white text-3xl lg:text-4xl font-light leading-tight mb-8">
          {founder.name}
        </h3>

        <div class="w-8 h-px bg-white/10/50 mb-8"></div>

        <!-- Quote -->
        <blockquote class="text-white/60 text-base lg:text-lg font-light leading-relaxed italic mb-8 border-l-2 border-white/15 pl-5">
          "{quote}"
        </blockquote>

      </div>

      <!-- Bottom: CTA buttons -->
      <div class="flex flex-col gap-3">
        <a
          href={`/${lang}/equipo`}
          class="group flex items-center justify-center gap-3 text-white/70 hover:text-white text-[10px] tracking-[0.25em] uppercase py-4 transition-colors duration-200 cursor-pointer"
        >
          {t.teamPageLabel}
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="transition-transform duration-300 group-hover:translate-x-0.5"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a
          href={`/${lang}#contacto`}
          class="flex items-center justify-center gap-3 text-white/40 hover:text-white text-[10px] tracking-[0.25em] uppercase py-4 transition-colors duration-200 cursor-pointer"
        >
          {lang === 'es' ? 'Consultar' : 'Contact'}
          <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 17L17 7M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom padding -->
  <div class="pb-16 lg:pb-24"></div>

</section>
