---
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
  t: { rights: string };
}

const { lang, t } = Astro.props;
---

<footer class="bg-[#0D0D0B] border-t border-white/5">

  <!-- Main grid -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20 grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-6 md:divide-x md:divide-white/10">

    <!-- Left: Contact info -->
    <div class="flex flex-col gap-5 md:pr-12">
      <p class="text-white/60 text-[10px] tracking-[0.3em] uppercase font-medium">Contacto</p>
      <div class="flex flex-col gap-3 text-white/60 text-sm leading-relaxed text-center md:text-left">
        <p>Buenos Aires, Argentina</p>
        <a href="mailto:hola@liberaestudio.com" class="hover:text-white/60 transition-colors duration-200">
          hola@liberaestudio.com
        </a>
        <a href="https://wa.me/5491168794241" target="_blank" rel="noopener" class="hover:text-white/60 transition-colors duration-200">
          +54 9 11 6879-4241
        </a>
      </div>
    </div>

    <!-- Center: Brand + tagline + socials -->
    <div class="flex flex-col items-center justify-center gap-5 md:px-12 text-center">
      <img src="/images/isologo.png" alt="Líbera Estudio" class="h-24 w-auto" style="filter: brightness(0) invert(1);" />
      <p class="text-white/55 text-sm leading-relaxed max-w-[200px]">
        Arquitectura que se ve.
      </p>
      <div class="flex items-center gap-5">
        <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.behance.net/LeonardoFabPerez" target="_blank" rel="noopener" aria-label="Behance" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H0V5.021h6.953c5.476.081 5.58 5.444 2.72 6.906 3.461 1.26 3.577 8.061-3.207 8.061zM3 11h3.584c2.508 0 2.906-3-.312-3H3v3zm3.391 3H3v3.016h3.341c3.055 0 2.868-3.016.05-3.016z"/></svg>
        </a>
      </div>
    </div>

    <!-- Right: Services -->
    <div class="flex flex-col gap-5 md:pl-12">
      <p class="text-white/60 text-[10px] tracking-[0.3em] uppercase font-medium text-center md:text-left">Servicios</p>
      <ul class="flex flex-col gap-3 text-white/60 text-sm text-center md:text-left">
        <li>Renders exteriores</li>
        <li>Renders interiores</li>
        <li>Animaciones 3D</li>
        <li>Visualización de producto</li>
      </ul>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/5 py-5">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 flex flex-col sm:flex-row items-center justify-between gap-2">
      <span class="text-white/40 text-xs tracking-widest uppercase">
        © {new Date().getFullYear()} Líbera Estudio. {t.rights}
      </span>
      <a href={`/${lang === 'es' ? 'en' : 'es'}`} class="text-white/40 hover:text-white/60 text-xs tracking-widest uppercase transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40">
        {lang === 'es' ? 'English' : 'Español'}
      </a>
    </div>
  </div>

</footer>
