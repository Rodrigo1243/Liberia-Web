---
interface ServiceItem {
  title: string;
  description: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    items: ServiceItem[];
  };
}

const { t } = Astro.props;

const icons = [
  // Exterior
  `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path d="M3 21V10l9-7 9 7v11M9 21v-6h6v6"/></svg>`,
  // Interior
  `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>`,
  // Animation
  `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M10 8l6 4-6 4V8z"/></svg>`,
  // Product
  `<svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>`,
];
---

<section id="servicios" class="py-28 lg:py-40 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- Header -->
    <div class="mb-16 lg:mb-24">
      <h2
        class="font-display text-black text-4xl lg:text-5xl font-light"
        data-animate
      >
        {t.title}
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-black/4">
      {t.items.map((item, i) => (
        <div
          class="bg-white p-8 lg:p-10 flex flex-col gap-6 group hover:bg-black/[0.03] transition-colors duration-300 cursor-pointer"
          data-animate
        >
          <div>
            <h3 class="font-display text-[#0D0D0B] text-lg font-medium mb-3">{item.title}</h3>
            <p class="text-[#2A1015]/75 text-sm leading-relaxed font-medium">{item.description}</p>
          </div>
          <div class="mt-auto w-6 h-px bg-black/8 group-hover:w-12 group-hover:bg-[#0D0D0B] transition-all duration-300"></div>
        </div>
      ))}
    </div>

  </div>
</section>
