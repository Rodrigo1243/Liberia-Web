---
interface Props {
  t: {
    tagline: string;
    cta: string;
    scroll: string;
  };
  lang: string;
}

const { t, lang } = Astro.props;
---

<section
  id="hero"
  class="grain relative min-h-screen flex flex-col bg-[#0D0D0B] overflow-hidden"
>
  <!-- Background image — more visible -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero/REAR NIGHT VIEW.jpg.jpeg"
      alt="Render arquitectónico"
      class="w-full h-full object-cover opacity-80"
      loading="eager"
    />
    <!-- Subtle vignette only at edges -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0D0D0B]/80 via-transparent to-[#0D0D0B]/30"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0D0D0B]/30 via-transparent to-[#0D0D0B]/30"></div>
  </div>

  <!-- Giant centered title -->
  <div class="relative z-10 flex-1 flex items-center justify-center px-4">
    <h1
      id="hero-title"
      class="leading-none text-center select-none"
      style="font-weight: 400; font-size: clamp(4.5rem, 16vw, 17rem); letter-spacing: -0.02em;"
    >
      <img
        src="/images/isologo.png"
        alt="Líbera Estudio"
        class="w-auto mx-auto"
        style="height: clamp(10rem, 35vw, 38rem); filter: brightness(0) invert(1);"
      />
    </h1>
  </div>

  <!-- Bottom bar -->
  <div class="relative z-10 w-full px-6 lg:px-12 pb-10 flex items-end justify-between gap-6">

    <!-- Bottom left: tagline + subtitle -->
    <div id="hero-bottom-left" class="max-w-xs">
      <p class="font-display text-white text-xl lg:text-2xl font-semibold leading-tight mb-2">
        {t.tagline}
      </p>
      <p class="text-white/50 text-sm leading-relaxed">
        Renders · Animaciones · Visualización 3D
      </p>
    </div>

    <!-- Bottom center: scroll button -->
    <div id="hero-scroll-btn" class="flex-shrink-0">
      <a
        href={`/${lang}#portfolio`}
        class="flex items-center justify-center text-white/50 hover:text-white transition-colors duration-300 group"
        aria-label="Scroll"
      >
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="group-hover:translate-y-0.5 transition-transform duration-200">
          <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  #hero-title {
    opacity: 0;
    transform: translateY(60px);
  }
  #hero-bottom-left, #hero-scroll-btn {
    opacity: 0;
    transform: translateY(20px);
  }
</style>

<script>
  import gsap from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    ['#hero-title', '#hero-bottom-left', '#hero-scroll-btn'].forEach((id) => {
      const el = document.querySelector(id) as HTMLElement | null;
      if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
    });
  } else {
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    tl.to('#hero-title',       { opacity: 1, y: 0, duration: 1.1, delay: 0.1 })
      .to('#hero-bottom-left', { opacity: 1, y: 0, duration: 0.7 }, '-=0.5')
      .to('#hero-scroll-btn',  { opacity: 1, y: 0, duration: 0.5 }, '-=0.5');
  }
</script>
